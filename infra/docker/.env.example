# Docker Compose production environment
# Copy this file to infra/docker/.env and fill in real values.
# Never commit the .env file.

# ── PostgreSQL ────────────────────────────────────────────────────────────────

POSTGRES_DB=lms
POSTGRES_USER=lms_user
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── API ───────────────────────────────────────────────────────────────────────

# Must match the postgres service credentials above.
DATABASE_URL=postgresql://lms_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/lms

# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# Public URL where the web container is reachable (for API CORS).
# Use your domain if running behind a reverse proxy, or http://localhost for local testing.
FRONTEND_URL=http://localhost

# ── Web ───────────────────────────────────────────────────────────────────────

# Host port to bind the web/nginx container.
WEB_PORT=80
