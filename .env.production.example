# =============================================================================
# Production environment variables — copy to Railway dashboard
# =============================================================================
# DO NOT commit real values. This file contains only placeholders.
# =============================================================================

# ── Runtime ──────────────────────────────────────────────────────────────────

NODE_ENV=production

# Railway injects PORT automatically — do NOT set API_PORT manually on Railway.
# The API reads PORT and maps it to API_PORT internally.
# API_PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────

# Provided automatically by Railway PostgreSQL plugin.
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB

# ── Authentication ───────────────────────────────────────────────────────────

# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32

# ── CORS ─────────────────────────────────────────────────────────────────────

# Public URL of the web service on Railway.
# Example: https://lms-web.up.railway.app
# The API allows cross-origin requests only from this origin.
FRONTEND_URL=https://YOUR_WEB_SERVICE.up.railway.app

# ── Storage (S3-compatible) ──────────────────────────────────────────────────
# Optional for MVP. Leave blank to disable file uploads.
# Use Cloudflare R2 or AWS S3 in production.

# S3_ENDPOINT=https://YOUR_ACCOUNT.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=lms-prod
# S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY
# S3_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
# S3_FORCE_PATH_STYLE=false        # set true for MinIO / self-hosted S3
# S3_PUBLIC_URL=https://pub.YOUR_DOMAIN.com  # if bucket is public-read; omit to use presigned URLs
