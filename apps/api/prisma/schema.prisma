generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  invited
  suspended
  archived
}

enum OrganizationStatus {
  active
  suspended
  archived
}

enum OrganizationPlan {
  trial
  standard
  enterprise
}

enum UserRole {
  learner
  instructor
  manager
  admin
}

enum GroupStatus {
  active
  archived
}

enum CourseStatus {
  draft
  published
  archived
}

enum LessonStatus {
  draft
  published
  archived
}

enum CourseMaterialStatus {
  active
  archived
}

enum CourseMaterialKind {
  file
  link
}

enum AssignmentStatus {
  assigned
  completed
  cancelled
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}

enum AssessmentStatus {
  draft
  published
  archived
}

enum AssessmentQuestionType {
  single_choice
  multiple_choice
  true_false
}

enum AssessmentAttemptStatus {
  completed
}

enum CertificateStatus {
  issued
  revoked
}

model Organization {
  id                              String                         @id @default(uuid()) @db.Uuid
  name                            String
  slug                            String                         @unique
  status                          OrganizationStatus             @default(active)
  plan                            OrganizationPlan               @default(trial)
  createdAt                       DateTime                       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                       DateTime                       @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                       DateTime?                      @map("deleted_at") @db.Timestamptz

  users                           User[]
  groups                          Group[]
  courses                         Course[]
  assignments                     Assignment[]
  progress                        Progress[]
  assessments                     Assessment[]
  assessmentQuestions             AssessmentQuestion[]
  assessmentAnswerOptions         AssessmentAnswerOption[]
  assessmentAttempts              AssessmentAttempt[]
  assessmentAttemptAnswers        AssessmentAttemptAnswer[]
  certificates                    Certificate[]
  memberships                     Membership[]

  @@map("organizations")
}

model User {
  id                  String              @id @default(uuid()) @db.Uuid
  organizationId      String              @map("organization_id") @db.Uuid
  email               String
  passwordHash        String              @map("password_hash")
  firstName           String              @map("first_name")
  lastName            String              @map("last_name")
  middleName          String?             @map("middle_name")
  position            String?
  shift               String?
  phone               String?
  status              UserStatus          @default(active)
  locale              String              @default("ru")
  timezone            String              @default("Asia/Almaty")
  lastLoginAt         DateTime?           @map("last_login_at") @db.Timestamptz
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt           DateTime?           @map("deleted_at") @db.Timestamptz

  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  memberships         Membership[]        @relation("UserMemberships")
  assignedMemberships Membership[]        @relation("MembershipAssignedBy")
  assignments         Assignment[]
  progress            Progress[]
  assessmentAttempts  AssessmentAttempt[]
  certificates        Certificate[]

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@index([lastLoginAt])
  @@map("users")
}

model Group {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  slug           String
  description    String?
  status         GroupStatus  @default(active)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    Assignment[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("groups")
}

model Course {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  title          String
  slug           String
  description    String?
  status         CourseStatus     @default(draft)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lessons        Lesson[]
  materials      CourseMaterial[]
  assignments    Assignment[]
  progress       Progress[]
  assessments    Assessment[]
  certificates   Certificate[]

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("courses")
}
