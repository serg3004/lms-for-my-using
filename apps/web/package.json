    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
